# Plantilla para copiar a application.properties (o perfil local).
# No subir application.properties con contraseñas ni jwt.secret reales al repo.

spring.application.name=e-commerce

# --- Base de datos MySQL (obligatorio si usás este bloque; el servidor debe estar levantado) ---
spring.datasource.url=jdbc:mysql://localhost:3306/ecommerce_db?createDatabaseIfNotExist=true&useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
spring.datasource.username=root
spring.datasource.password=TU_PASSWORD_MYSQL
spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver

# --- JPA / Hibernate ---
spring.jpa.database-platform=org.hibernate.dialect.MySQLDialect
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=true
spring.jpa.properties.hibernate.format_sql=true
# Opcional: datos seed (ver data.sql en el proyecto).
# spring.jpa.defer-datasource-initialization=true
# spring.sql.init.mode=always

# --- JWT (obligatorio: JwtUtil falla si faltan) ---
# HS256: secreto >= 32 caracteres UTF-8. Cambiar en cada entorno.
jwt.secret=CAMBIA_POR_UNA_CLAVE_SECRETA_DE_AL_MENOS_32_CARACTERES
# Vida del token en ms (86400000 = 24 h).
jwt.expiration=86400000

# --- CORS (SecurityConfig lee app.cors.allowed-origins) ---
app.cors.allowed-origins=http://localhost:5173,http://localhost:3000

# --- Pagos mock (PagoService; obligatorio definir para evitar ambigüedad) ---
app.payments.mock-enabled=true
app.payments.mock-random-outcome=false
app.payments.mock-rechazo-cancela-pedido=false

# --- springdoc / Swagger (misma app; si no definís, springdoc usa defaults) ---
springdoc.packages-to-scan=com.uade.tpo.ecommerce
springdoc.swagger-ui.path=/swagger-ui.html
springdoc.swagger-ui.operationsSorter=method
springdoc.swagger-ui.tagsSorter=alpha

# --- Alternativa local: H2 en memoria (comentá el bloque MySQL de arriba y descomentá esto) ---
# spring.datasource.url=jdbc:h2:mem:testdb;MODE=MySQL;DB_CLOSE_DELAY=-1;DB_CLOSE_ON_EXIT=FALSE
