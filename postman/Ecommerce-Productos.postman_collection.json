{
  "info": {
    "name": "Ecommerce API",
    "description": "Bulk: productos, usuarios y pedidos. Pedidos simples (sin líneas de producto). Base: {{baseUrl}}.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    }
  ],
  "item": [
    {
      "name": "Productos",
      "item": [
        {
          "name": "Bulk save",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "[\n  { \"nombre\": \"Mouse Logitech G203\", \"descripcion\": \"Óptico, 8000 DPI, RGB\" },\n  { \"nombre\": \"Teclado Keychron K2\", \"descripcion\": \"Mecánico 75%, Bluetooth\" },\n  { \"nombre\": \"Monitor LG 27\", \"descripcion\": \"QHD 144Hz\" },\n  { \"nombre\": \"Webcam Logitech C920\", \"descripcion\": \"1080p\" },\n  { \"nombre\": \"Auriculares HyperX Cloud II\", \"descripcion\": \"7.1 virtual\" },\n  { \"nombre\": \"SSD Samsung 990 PRO 1TB\", \"descripcion\": \"NVMe PCIe 4.0\" },\n  { \"nombre\": \"RAM Corsair 32GB\", \"descripcion\": \"DDR5 6000 MHz\" },\n  { \"nombre\": \"RTX 4070\", \"descripcion\": \"12GB GDDR6X\" },\n  { \"nombre\": \"Gabinete NZXT H5\", \"descripcion\": \"Mid tower airflow\" },\n  { \"nombre\": \"Fuente Corsair RM850e\", \"descripcion\": \"850W Gold modular\" }\n]"
            },
            "url": "{{baseUrl}}/api/productos/bulk",
            "description": "Array de productos. Sin `id`. `nombre` obligatorio, `descripcion` opcional."
          },
          "response": []
        },
        {
          "name": "Get all",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/productos",
            "description": "Lista todos los productos."
          },
          "response": []
        },
        {
          "name": "Create one",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Producto de prueba\",\n  \"descripcion\": \"Alta individual\"\n}"
            },
            "url": "{{baseUrl}}/api/productos",
            "description": "Un solo producto por POST."
          },
          "response": []
        },
        {
          "name": "Get by id",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/productos/1",
            "description": "Cambiá el 1 por el id que te devolvió la API."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Usuarios",
      "item": [
        {
          "name": "Create",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Ana García\",\n  \"email\": \"ana@mail.com\"\n}"
            },
            "url": "{{baseUrl}}/api/usuarios",
            "description": "`email` único. Creá al menos un usuario antes de los pedidos."
          },
          "response": []
        },
        {
          "name": "Bulk create",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "[\n  { \"nombre\": \"Ana García\", \"email\": \"ana.bulk@mail.com\" },\n  { \"nombre\": \"Luis Pérez\", \"email\": \"luis.bulk@mail.com\" },\n  { \"nombre\": \"María López\", \"email\": \"maria.bulk@mail.com\" }\n]"
            },
            "url": "{{baseUrl}}/api/usuarios/bulk",
            "description": "Array de usuarios. Sin `id`. Cada `email` debe ser distinto."
          },
          "response": []
        },
        {
          "name": "Get all",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/usuarios",
            "description": "Lista usuarios."
          },
          "response": []
        },
        {
          "name": "Get by id",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/usuarios/1",
            "description": "Ajustá el id según el usuario creado."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Pedidos",
      "item": [
        {
          "name": "Create",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"usuario\": { \"id\": 1 },\n  \"estado\": \"PENDIENTE\"\n}"
            },
            "url": "{{baseUrl}}/api/pedidos",
            "description": "Pedido simple: solo usuario (por id) y estado. Si no mandás `estado` ni `fechaCreacion`, el backend completa solo. Valores de estado: PENDIENTE, CONFIRMADO, ENVIADO, ENTREGADO, CANCELADO. Cambiá `usuario.id` si tu usuario no es 1."
          },
          "response": []
        },
        {
          "name": "Bulk create",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "[\n  { \"usuario\": { \"id\": 1 }, \"estado\": \"PENDIENTE\" },\n  { \"usuario\": { \"id\": 1 }, \"estado\": \"CONFIRMADO\" },\n  { \"usuario\": { \"id\": 2 }, \"estado\": \"PENDIENTE\" }\n]"
            },
            "url": "{{baseUrl}}/api/pedidos/bulk",
            "description": "Varios pedidos en un solo POST. Todos los `usuario.id` tienen que existir. Si uno falla, no se guarda ninguno (respuesta vacía / null)."
          },
          "response": []
        },
        {
          "name": "Get all",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/pedidos",
            "description": "Todos los pedidos."
          },
          "response": []
        },
        {
          "name": "Get by usuario",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/pedidos/usuario/1",
            "description": "Pedidos de un usuario. Cambiá el último número por el id de usuario."
          },
          "response": []
        },
        {
          "name": "Get by id",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/pedidos/1",
            "description": "Un pedido por id."
          },
          "response": []
        },
        {
          "name": "Update estado",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"estado\": \"CONFIRMADO\"\n}"
            },
            "url": "{{baseUrl}}/api/pedidos/1",
            "description": "Solo actualiza el estado. Ajustá la URL al id del pedido."
          },
          "response": []
        }
      ]
    }
  ]
}
